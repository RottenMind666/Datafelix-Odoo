<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_mrc_nrc_totals" model="ir.ui.view">
        <field name="name">sale.order.form.datafelix.mrc.nrc</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//form//field[@name='price_unit']" position="after">
                <field name="una_tantum_price" string="NRC" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='price_unit']" position="after">
                <field name="una_tantum_price" string="NRC" readonly="1" optional="show"/>
            </xpath>
            <xpath expr="//group[@name='sale_total']/field[@name='tax_totals']" position="after">
                <field name="total_mrc" invisible="1" readonly="1"/>
                <field name="total_nrc" invisible="1" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_x_ut" model="ir.ui.view">
        <field name="name">product.template.form.x.ut</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='list_price_uom']" position="after">
                <label for="x_ut"/>
                <div name="x_ut_uom">
                    <field
                        name="x_ut"
                        class="oe_inline"
                        widget="monetary"
                        options="{'currency_field': 'currency_id', 'field_digits': True}"
                    />
                </div>
            </xpath>
        </field>
    </record>

    <record id="view_product_product_form_x_ut" model="ir.ui.view">
        <field name="name">product.product.form.x.ut</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lst_price']" position="after">
                <field
                    name="x_ut"
                    class="oe_inline"
                    widget="monetary"
                    options="{'currency_field': 'currency_id', 'field_digits': True}"
                />
            </xpath>
        </field>
    </record>

    <record id="view_product_template_kanban_x_ut" model="ir.ui.view">
        <field name="name">product.template.kanban.x.ut</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban/field[@name='categ_id']" position="after">
                <field name="x_ut"/>
            </xpath>
            <xpath expr="//t[@t-name='card']/main/field[@name='product_properties']" position="before">
                <t t-if="record.x_ut.raw_value">
                    <span>
                        Una Tantum:
                        <field
                            name="x_ut"
                            widget="monetary"
                            options="{'currency_field': 'currency_id', 'field_digits': True}"
                        />
                    </span>
                </t>
                <t t-else="">
                    <span class="text-muted">Una Tantum: -</span>
                </t>
            </xpath>
        </field>
    </record>
</odoo>

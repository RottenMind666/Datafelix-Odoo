<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-inherit="account.TaxTotalsField" t-inherit-mode="extension" owl="1">
        <xpath expr="//span[@name='amount_total']/ancestor::tr[1]" position="before">
            <tr t-if="props.record.fields.total_mrc">
                <td class="o_td_label">
                    <label class="o_form_label o_tax_total_label">Totale MRC</label>
                </td>
                <td class="o_list_monetary">
                    <span
                        name="total_mrc"
                        style="white-space: nowrap; font-weight: bold;"
                        dir="ltr"
                        t-out="formatMonetary(props.record.data.total_mrc || 0)"
                    />
                </td>
            </tr>
            <tr t-if="props.record.fields.total_nrc">
                <td class="o_td_label">
                    <label class="o_form_label o_tax_total_label">Totale NRC</label>
                </td>
                <td class="o_list_monetary">
                    <span
                        name="total_nrc"
                        style="white-space: nowrap; font-weight: bold;"
                        dir="ltr"
                        t-out="formatMonetary(props.record.data.total_nrc || 0)"
                    />
                </td>
            </tr>
        </xpath>
    </t>
</templates>